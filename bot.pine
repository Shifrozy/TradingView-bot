//@version=6
indicator("Candle-Reader Dashboard - Phase 1", overlay=true, max_lines_count=500, max_labels_count=500)

// ──────────────── USER INPUTS ────────────────
tablePos       = input.string("Top Right", "Table Position", options=["Top Left","Top Right","Bottom Left","Bottom Right"])
tfList         = input.string("1,3,5,15,30,60,240", "Timeframes (comma-separated)")
historyLength  = input.int(5, "History Length", minval=3, maxval=10)
showMarkers    = input.bool(true, "Show Chart Markers")

// ──────────────── HELPER FUNCTIONS ────────────────
isBullish(o,c) => c > o
isBearish(o,c) => c < o

detectPattern(o,h,l,c) =>
    body     = math.abs(c - o)
    upperW   = h - math.max(c,o)
    lowerW   = math.min(c,o) - l
    bodyPct  = body / (h - l + 1e-10)

    pattern  = ""
    dir      = 0   // +1 bull, -1 bear, 0 neutral

    if bodyPct < 0.1
        pattern := "Doji"
        dir := 0
    else if bodyPct > 0.9
        pattern := c > o ? "Marubozu Bull" : "Marubozu Bear"
        dir := c > o ? +1 : -1
    else if lowerW > 2*body and upperW < body
        pattern := "Hammer"
        dir := +1
    else if upperW > 2*body and lowerW < body
        pattern := "Shooting Star"
        dir := -1
    else if bodyPct < 0.3
        pattern := "Spinning Top"
        dir := 0

    [pattern, dir]

// Engulfing (multi-candle)
detectEngulfing(o1,h1,l1,c1,o2,h2,l2,c2) =>
    bull = c2 > o2 and o1 > c1 and c2 >= h1 and o2 <= l1
    bear = o2 > c2 and c1 > o1 and o2 >= h1 and c2 <= l1
    pattern = bull ? "Bull Engulfing" : bear ? "Bear Engulfing" : ""
    dir     = bull ? +1 : bear ? -1 : 0
    [pattern, dir]

// Inside Bar
detectInside(h1,l1,h2,l2) =>
    inside = h2 < h1 and l2 > l1
    [inside ? "Inside Bar" : "", 0]

// ──────────────── TABLE SETUP ────────────────
var dashTable = table.new(
     position = tablePos == "Top Left" ? position.top_left :
                tablePos == "Top Right" ? position.top_right :
                tablePos == "Bottom Left" ? position.bottom_left :
                position.bottom_right,
     columns = 3, rows = 50, border_width=1)

// ──────────────── PROCESS EACH TIMEFRAME ────────────────
tfs = str.split(tfList, ",")
row = 0
for tf in tfs
    tf_str = str.trim(tf)
    [o,h,l,c] = request.security(syminfo.tickerid, tf_str, [open, high, low, close], lookahead=barmerge.lookahead_off)
    [o1,h1,l1,c1] = request.security(syminfo.tickerid, tf_str, [open[1], high[1], low[1], close[1]], lookahead=barmerge.lookahead_off)

    [pat1, dir1] = detectPattern(o,h,l,c)
    [patE, dirE] = detectEngulfing(o1,h1,l1,c1,o,h,l,c)
    [patI, dirI] = detectInside(h1,l1,h,l)

    patFinal = patE != "" ? patE : patI != "" ? patI : pat1
    dirFinal = patE != "" ? dirE : patI != "" ? 0 : dir1

    // ─── Display in table ───
    table.cell(dashTable, 0, row, tf_str, bgcolor=color.gray)
    table.cell(dashTable, 1, row, patFinal, bgcolor=dirFinal==1?color.new(color.green,80):dirFinal==-1?color.new(color.red,80):color.new(color.yellow,80))
    table.cell(dashTable, 2, row, dirFinal==1?"Bullish":dirFinal==-1?"Bearish":"Neutral")

    // ─── Markers ───
    if showMarkers and barstate.isconfirmed
        if dirFinal == 1
            label.new(bar_index, low, "▲", color=color.green, style=label.style_label_up, textcolor=color.white, size=size.tiny)
        if dirFinal == -1
            label.new(bar_index, high, "▼", color=color.red, style=label.style_label_down, textcolor=color.white, size=size.tiny)

    row += 1
